    filename='automation.log',
    level=logging.DEBUG,
    format='%(asctime)s - %(message)s'
)
 
logging.info(f"Picked orange at {pos}")
```
 
### Add Break Timer
```python
if cycle_count % 50 == 0:  # Every 50 cycles
    print("Taking break...")
